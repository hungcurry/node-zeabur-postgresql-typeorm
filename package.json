{
  "name": "node-zeabur-postgresql",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --exec tsx index.ts",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "typeorm:prod": "node ./node_modules/typeorm/cli.js -d ./dist/src/config/database.js",
    "migration:run:prod": "npm run typeorm:prod -- migration:run",
    "prestart": "cross-env NODE_ENV=production npm run migration:run:prod",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "clean:port": "npx kill-port 8080",
    "typeorm": "tsx ./node_modules/typeorm/cli.js -d ./src/config/database.ts",
    "migration:generate": "cross-var npm run typeorm -- migration:generate src/migrations/$npm_config_name",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-roll": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-var": "^1.1.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
